{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*\\.(?:ico|svg|png|jpg|jpeg|webp|woff2?))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/site.webmanifest", "destination": "/site.webmanifest" },
    { "source": "/services", "destination": "/services.html" },
    { "source": "/masters", "destination": "/masters.html" },
    { "source": "/prices", "destination": "/prices.html" },
    { "source": "/reviews", "destination": "/reviews.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
